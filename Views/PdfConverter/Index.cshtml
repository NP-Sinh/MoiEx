@{
    ViewData["Title"] = "PDF Converter";
    Layout = "_Layout";
}

<!-- Tool Page -->
<section class="tool-page">
    <div class="container">
        <!-- Page Header -->
        <div class="tool-header-row">
            <div>
                <h1 class="tool-page-title">PDF Converter</h1>
                <p class="tool-page-sub">Chuyển đổi ảnh, Word, TXT, CSV, MD sang PDF — hỗ trợ hàng loạt file.</p>
            </div>
            <div class="tool-header-actions">
                <button class="tool-action-btn tool-action-btn--primary">
                    <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" /></svg>
                    Chia sẻ
                </button>
            </div>
        </div>

        <!-- 3-column layout -->
        <div class="tool-layout">

            <!-- LEFT: How to use -->
            <aside class="tool-sidebar-left">
                <div class="tool-info-card">
                    <div class="tool-info-header">
                        <svg width="15" height="15" fill="none" stroke="var(--clr-blue)" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                        Cách sử dụng
                    </div>
                    <ol class="tool-steps">
                        <li>
                            <span class="tool-step-num">1</span>
                            <span>Kéo thả hoặc chọn file (ảnh, DOCX, TXT, CSV, MD) — tối đa 20 file</span>
                        </li>
                        <li>
                            <span class="tool-step-num">2</span>
                            <span>Chọn hướng trang và các tùy chọn chuyển đổi</span>
                        </li>
                        <li>
                            <span class="tool-step-num">3</span>
                            <span>Nhấn <strong>Chuyển đổi</strong> — tải về file PDF hoặc ZIP</span>
                        </li>
                    </ol>
                    <div class="tool-pro-tip">
                        <span class="tool-pro-badge">PRO TIP</span>
                        <p>Khi tải lên nhiều ảnh cùng lúc, các ảnh sẽ được <strong>gộp vào một file PDF</strong> theo thứ tự bạn chọn.</p>
                    </div>
                </div>

                <!-- Stats -->
                <div class="tool-stats-card">
                    <div class="tool-stat">
                        <span class="tool-stat-val" id="statCount">0</span>
                        <span class="tool-stat-label">File đã chọn</span>
                    </div>
                    <div class="tool-stat-divider"></div>
                    <div class="tool-stat">
                        <span class="tool-stat-val" id="statSize">0 KB</span>
                        <span class="tool-stat-label">Tổng kích thước</span>
                    </div>
                    <div class="tool-stat-divider"></div>
                    <div class="tool-stat">
                        <span class="tool-stat-val" id="statOutput">—</span>
                        <span class="tool-stat-label">Đầu ra</span>
                    </div>
                </div>
            </aside>

            <!-- CENTER: Drop Zone + File List -->
            <div class="tool-workspace">
                <!-- Drop Zone -->
                <div class="tool-dropzone" id="dropzone" style="display:flex;">
                    <div class="tool-dropzone-inner" id="dropzoneInner">
                        <div class="tool-drop-icon">
                            <svg width="40" height="40" fill="none" stroke="currentColor" viewBox="0 0 24 24" opacity=".45">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                            </svg>
                        </div>
                        <p class="tool-drop-title">Thả file vào đây</p>
                        <p class="tool-drop-sub">Hỗ trợ JPG, PNG, BMP, GIF, TIFF, DOCX, TXT, CSV, MD — tối đa 20 file, mỗi file ≤ 100 MB</p>
                        <div class="tool-drop-btns">
                            <button class="tool-action-btn tool-action-btn--primary" id="selectFilesBtn">
                                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                                Chọn file
                            </button>
                        </div>
                        <input type="file" id="fileInput"
                               accept=".jpg,.jpeg,.png,.bmp,.gif,.tiff,.tif,.docx,.txt,.csv,.md"
                               multiple hidden />
                        <div class="tool-drop-badges">
                            <span class="tool-drop-badge">
                                <svg width="11" height="11" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
                                Mã hóa đầu cuối
                            </span>
                            <span class="tool-drop-badge">
                                <svg width="11" height="11" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                                Xử lý nhanh
                            </span>
                        </div>
                    </div>
                </div>

                <!-- File Preview List (hidden until files selected) -->
                <div class="tool-file-list" id="fileList" style="display:none;">
                    <div class="tool-file-list-header">
                        <span class="tool-file-list-title" id="fileListTitle">0 file đã chọn</span>
                        <button class="tool-clear-btn" id="clearAllBtn">
                            <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                            Xóa tất cả
                        </button>
                    </div>
                    <div class="tool-file-grid" id="fileGrid"></div>
                    <button class="tool-add-more-btn" id="addMoreBtn">
                        <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                        Thêm file
                    </button>
                </div>

                <!-- Progress (hidden until converting) -->
                <div class="tool-progress-wrap" id="progressWrap" style="display:none;">
                    <div class="tool-progress-label">
                        <span id="progressText">Đang chuyển đổi…</span>
                        <span id="progressPct">0%</span>
                    </div>
                    <div class="tool-progress-bar">
                        <div class="tool-progress-fill" id="progressFill" style="width:0%"></div>
                    </div>
                </div>
            </div>

            <!-- RIGHT: Settings -->
            <aside class="tool-sidebar-right">
                <div class="tool-settings-card">
                    <div class="tool-settings-title">
                        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                        Cài đặt chuyển đổi
                    </div>

                    <!-- Page Orientation -->
                    <div class="tool-setting-group">
                        <label class="tool-setting-label">HƯỚNG TRANG</label>
                        <div class="tool-format-grid">
                            <button class="tool-format-btn is-active" data-orient="auto">
                                <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2v-4M9 21H5a2 2 0 01-2-2v-4m0 0h18" /></svg>
                                Tự động
                            </button>
                            <button class="tool-format-btn" data-orient="portrait">
                                <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="5" y="2" width="14" height="20" rx="2" stroke-width="1.5" /></svg>
                                Dọc
                            </button>
                            <button class="tool-format-btn" data-orient="landscape">
                                <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="2" y="5" width="20" height="14" rx="2" stroke-width="1.5" /></svg>
                                Ngang
                            </button>
                        </div>
                    </div>

                    <!-- Toggles -->
                    <div class="tool-setting-group">
                        <label class="tool-setting-label">TÙY CHỌN</label>
                        <div class="tool-toggle-row">
                            <div class="tool-toggle-info">
                                <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                                <span>Nén file PDF đầu ra</span>
                            </div>
                            <label class="tool-toggle">
                                <input type="checkbox" id="compressToggle" />
                                <span class="tool-toggle-track"></span>
                            </label>
                        </div>
                        <div class="tool-toggle-row">
                            <div class="tool-toggle-info">
                                <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                                <span>Bật OCR (nhận dạng chữ)</span>
                            </div>
                            <label class="tool-toggle">
                                <input type="checkbox" id="ocrToggle" />
                                <span class="tool-toggle-track"></span>
                            </label>
                        </div>
                    </div>

                    <!-- Convert Button -->
                    <button class="tool-compress-btn" id="convertBtn" disabled>
                        <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
                        Chuyển đổi
                    </button>
                    <p class="tool-compress-note">
                        Bằng cách chuyển đổi, bạn đồng ý với <a href="#">điều khoản xử lý</a> của chúng tôi.
                    </p>
                </div>
            </aside>

        </div>
    </div>
</section>

<script>
    (function () {
        const fileInput = document.getElementById('fileInput');
        const selectBtn = document.getElementById('selectFilesBtn');
        const addMoreBtn = document.getElementById('addMoreBtn');
        const dropzone = document.getElementById('dropzone');
        const fileList = document.getElementById('fileList');
        const fileGrid = document.getElementById('fileGrid');
        const fileListTitle = document.getElementById('fileListTitle');
        const clearAllBtn = document.getElementById('clearAllBtn');
        const convertBtn = document.getElementById('convertBtn');
        const progressWrap = document.getElementById('progressWrap');
        const progressFill = document.getElementById('progressFill');
        const progressText = document.getElementById('progressText');
        const progressPct = document.getElementById('progressPct');
        const statCount = document.getElementById('statCount');
        const statSize = document.getElementById('statSize');
        const statOutput = document.getElementById('statOutput');
        const orientBtns = document.querySelectorAll('.tool-format-btn[data-orient]');

        const MAX_FILES = 20;
        const MAX_FILE_SIZE = 100 * 1024 * 1024; // 100 MB

        const ACCEPTED_EXTS = ['.jpg', '.jpeg', '.png', '.bmp', '.gif', '.tiff', '.tif', '.docx', '.txt', '.csv', '.md'];
        const IMAGE_EXTS = ['.jpg', '.jpeg', '.png', '.bmp', '.gif', '.tiff', '.tif'];

        let files = [];
        let selectedOrientation = 'auto';

        // File type icon map
        const EXT_ICONS = {
            docx: `<svg width="22" height="22" fill="none" stroke="var(--clr-blue)" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>`,
            txt: `<svg width="22" height="22" fill="none" stroke="var(--clr-muted)" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h7"/></svg>`,
            csv: `<svg width="22" height="22" fill="none" stroke="#34d399" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M3 14h18M10 3v18"/></svg>`,
            md: `<svg width="22" height="22" fill="none" stroke="#a78bfa" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/></svg>`,
        };

        // ---- Orientation selector ----
        orientBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                orientBtns.forEach(b => b.classList.remove('is-active'));
                btn.classList.add('is-active');
                selectedOrientation = btn.dataset.orient;
            });
        });

        // ---- File picking ----
        selectBtn.addEventListener('click', () => fileInput.click());
        addMoreBtn.addEventListener('click', () => fileInput.click());
        fileInput.addEventListener('change', () => addFiles(fileInput.files));

        // ---- Drag & drop ----
        ['dragenter', 'dragover'].forEach(ev => dropzone.addEventListener(ev, e => { e.preventDefault(); dropzone.classList.add('drag-over'); }));
        ['dragleave', 'drop'].forEach(ev => dropzone.addEventListener(ev, e => { e.preventDefault(); dropzone.classList.remove('drag-over'); }));
        dropzone.addEventListener('drop', e => addFiles(e.dataTransfer.files));

        function getExt(name) {
            const m = name.match(/(\.[^.]+)$/);
            return m ? m[1].toLowerCase() : '';
        }

        function isImage(name) {
            return IMAGE_EXTS.includes(getExt(name));
        }

        function addFiles(newFiles) {
            const arr = Array.from(newFiles).filter(f => ACCEPTED_EXTS.includes(getExt(f.name)));
            const remaining = MAX_FILES - files.length;
            if (remaining <= 0) { alert('Đã đạt giới hạn 20 file.'); return; }
            const oversized = arr.filter(f => f.size > MAX_FILE_SIZE);
            if (oversized.length > 0) {
                alert(`File "${oversized[0].name}" vượt quá giới hạn 100 MB.`);
                return;
            }
            arr.slice(0, remaining).forEach(f => files.push(f));
            renderFileList();
            fileInput.value = '';
        }

        function renderFileList() {
            fileGrid.innerHTML = '';
            files.forEach((f, idx) => {
                const item = document.createElement('div');
                item.className = 'tool-file-item';
                const ext = getExt(f.name).replace('.', '');

                if (isImage(f.name)) {
                    const url = URL.createObjectURL(f);
                    item.innerHTML = `
                        <img class="tool-file-thumb" src="${url}" alt="${f.name}" />
                        <div class="tool-file-overlay">
                            <span class="tool-file-name">${f.name}</span>
                            <span class="tool-file-size">${fmtSize(f.size)}</span>
                        </div>
                        <button class="tool-file-remove" data-idx="${idx}" title="Xóa file">
                            <svg width="9" height="9" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"/></svg>
                        </button>`;
                } else {
                    const icon = EXT_ICONS[ext] || EXT_ICONS['txt'];
                    item.innerHTML = `
                        <div class="tool-file-doc-thumb">
                            ${icon}
                            <span class="tool-file-doc-ext">${ext.toUpperCase()}</span>
                        </div>
                        <div class="tool-file-overlay tool-file-overlay--always">
                            <span class="tool-file-name">${f.name}</span>
                            <span class="tool-file-size">${fmtSize(f.size)}</span>
                        </div>
                        <button class="tool-file-remove" data-idx="${idx}" title="Xóa file">
                            <svg width="9" height="9" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"/></svg>
                        </button>`;
                }
                fileGrid.appendChild(item);
            });

            // Remove handlers
            fileGrid.querySelectorAll('.tool-file-remove').forEach(btn => {
                btn.addEventListener('click', () => {
                    files.splice(parseInt(btn.dataset.idx), 1);
                    renderFileList();
                });
            });

            const visible = files.length > 0;
            dropzone.style.display = visible ? 'none' : 'flex';
            fileList.style.display = visible ? 'block' : 'none';
            fileListTitle.textContent = `${files.length} file đã chọn`;
            convertBtn.disabled = files.length === 0;

            // Stats
            const totalBytes = files.reduce((s, f) => s + f.size, 0);
            statCount.textContent = files.length;
            statSize.textContent = fmtSize(totalBytes);

            // Output label
            const imgCount = files.filter(f => isImage(f.name)).length;
            const allImages = imgCount === files.length;
            if (files.length === 0) {
                statOutput.textContent = '—';
            } else if (allImages && files.length > 1) {
                statOutput.textContent = '1 PDF';
            } else if (files.length === 1) {
                statOutput.textContent = '1 PDF';
            } else {
                statOutput.textContent = 'ZIP';
            }

            if (files.length === 0) {
                dropzone.style.display = 'flex';
                fileList.style.display = 'none';
            }
        }

        clearAllBtn.addEventListener('click', () => { files = []; renderFileList(); });

        // ---- Convert ----
        convertBtn.addEventListener('click', async () => {
            if (files.length === 0) return;

            const compress = document.getElementById('compressToggle').checked;
            const ocr = document.getElementById('ocrToggle').checked;

            convertBtn.disabled = true;
            convertBtn.innerHTML = '<span class="btn-spinner"></span> Đang chuyển đổi…';
            progressWrap.style.display = 'block';

            const formData = new FormData();
            files.forEach(f => formData.append('files', f));
            formData.append('compressOutput', compress);
            formData.append('enableOcr', ocr);
            formData.append('pageOrientation', selectedOrientation);

            try {
                let pct = 0;
                const ticker = setInterval(() => {
                    pct = Math.min(pct + Math.random() * 10, 88);
                    updateProgress(pct, 'Đang chuyển đổi…');
                }, 250);

                const res = await fetch('/moiex/PdfConverter/convert', {
                    method: 'POST',
                    body: formData
                });

                clearInterval(ticker);

                if (!res.ok) throw new Error(await res.text());

                updateProgress(100, 'Hoàn tất!');

                const contentDisp = res.headers.get('Content-Disposition') || '';
                const fileName = contentDisp.match(/filename="?([^";]+)"?/)?.[1]
                    || (files.length > 1 ? 'converted_pdfs.zip' : `${files[0].name.replace(/\.[^.]+$/, '')}.pdf`);

                const blob = await res.blob();

                // Mark items as done
                fileGrid.querySelectorAll('.tool-file-item').forEach(item => {
                    if (!item.querySelector('.tool-file-result')) {
                        const badge = document.createElement('div');
                        badge.className = 'tool-file-result';
                        badge.textContent = '✓';
                        item.appendChild(badge);
                    }
                });

                // Download
                const a = document.createElement('a');
                a.href = URL.createObjectURL(blob);
                a.download = fileName;
                a.click();
                URL.revokeObjectURL(a.href);

            } catch (err) {
                updateProgress(0, 'Lỗi: ' + err.message);
                alert('Chuyển đổi thất bại: ' + err.message);
            } finally {
                setTimeout(() => { progressWrap.style.display = 'none'; }, 2000);
                convertBtn.disabled = false;
                convertBtn.innerHTML = `<svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg> Chuyển đổi`;
            }
        });

        function updateProgress(pct, text) {
            const p = Math.round(pct);
            progressFill.style.width = p + '%';
            progressPct.textContent = p + '%';
            progressText.textContent = text;
        }

        function fmtSize(bytes) {
            if (bytes < 1024) return bytes + ' B';
            if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
            return (bytes / 1024 / 1024).toFixed(2) + ' MB';
        }
    })();
</script>

<style>
    .tool-file-doc-thumb {
        width: 100%;
        aspect-ratio: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 6px;
        background: var(--clr-surface);
        border-radius: 6px;
    }

    .tool-file-doc-ext {
        font-size: 0.6rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        color: var(--clr-muted);
    }
    .tool-file-overlay--always {
        opacity: 1 !important;
    }
</style>
