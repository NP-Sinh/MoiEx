<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="img/png" href="~/img/logo.png" />
    <title>@ViewData["Title"] - MoiEx</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MoiEx.styles.css" asp-append-version="true" />
</head>
<body class="moiex-body">

    <!-- NAVBAR -->
    <header class="moiex-header">
        <nav class="moiex-nav container">
            <a href="/" class="moiex-logo">
                MoiEx
            </a>
            <div class="moiex-nav-links">
                <a href="#" class="moiex-nav-link">Tools</a>
                <a href="#" class="moiex-nav-link">Categories</a>
                <a href="#" class="moiex-nav-link">Workspace</a>
                <a href="#" class="moiex-nav-link">Library</a>
            </div>
            <div class="moiex-nav-right">
                <button class="moiex-icon-btn">
                    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                    </svg>
                </button>
                <!-- Theme Toggle -->
                <button class="moiex-icon-btn moiex-theme-btn" id="themeToggle" aria-label="Toggle theme" title="Chuyển giao diện">
                    <svg class="theme-icon-moon" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
                    </svg>
                    <svg class="theme-icon-sun" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
                    </svg>
                </button>
                <!-- Hamburger (mobile only) -->
                <button class="moiex-icon-btn moiex-hamburger" id="menuToggle" aria-label="Mở menu" aria-expanded="false">
                    <svg class="ham-icon-open" width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                    </svg>
                    <svg class="ham-icon-close" width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
        </nav>
    </header>

    <!-- Mobile Drawer -->
    <div class="moiex-mobile-drawer" id="mobileDrawer" aria-hidden="true">
        <nav class="moiex-mobile-nav">
            <a href="#" class="moiex-mobile-link">Tools</a>
            <a href="#" class="moiex-mobile-link">Categories</a>
            <a href="#" class="moiex-mobile-link">Workspace</a>
            <a href="#" class="moiex-mobile-link">Library</a>
        </nav>
    </div>
    <div class="moiex-drawer-overlay" id="drawerOverlay"></div>

    <!-- MAIN -->
    <main class="moiex-main">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="moiex-footer">
        <div class="moiex-footer-inner container">
            <div class="moiex-footer-brand">
                <span class="moiex-footer-name">MoiEx</span>
                <span class="moiex-footer-copy">© 2026 MoiEx Productivity Systems</span>
            </div>
            <div class="moiex-footer-links">
                <a href="#">Privacy Policy</a>
                <a href="#">Terms of Service</a>
                <a href="#">Help Center</a>
                <a href="#">Contact Us</a>
            </div>
            <div class="moiex-footer-icons">
                <button class="moiex-icon-btn">
                    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
                    </svg>
                </button>
                <button class="moiex-icon-btn">
                    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
                    </svg>
                </button>
            </div>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
    <script>
            (function () {
                // Theme
                var themeBtn = document.getElementById('themeToggle');
                var saved = localStorage.getItem('moiex-theme');
                if (saved === 'light') document.documentElement.setAttribute('data-theme', 'light');
                themeBtn.addEventListener('click', function () {
                    var isLight = document.documentElement.getAttribute('data-theme') === 'light';
                    if (isLight) {
                        document.documentElement.removeAttribute('data-theme');
                        localStorage.setItem('moiex-theme', 'dark');
                    } else {
                        document.documentElement.setAttribute('data-theme', 'light');
                        localStorage.setItem('moiex-theme', 'light');
                    }
                });

                // Mobile menu
                var menuBtn = document.getElementById('menuToggle');
                var drawer  = document.getElementById('mobileDrawer');
                var overlay = document.getElementById('drawerOverlay');

                function openMenu() {
                    drawer.classList.add('is-open');
                    overlay.classList.add('is-visible');
                    menuBtn.setAttribute('aria-expanded', 'true');
                    drawer.setAttribute('aria-hidden', 'false');
                    document.body.style.overflow = 'hidden';
                }
                function closeMenu() {
                    drawer.classList.remove('is-open');
                    overlay.classList.remove('is-visible');
                    menuBtn.setAttribute('aria-expanded', 'false');
                    drawer.setAttribute('aria-hidden', 'true');
                    document.body.style.overflow = '';
                }

                menuBtn.addEventListener('click', function () {
                    drawer.classList.contains('is-open') ? closeMenu() : openMenu();
                });
                overlay.addEventListener('click', closeMenu);
                window.addEventListener('resize', function () {
                    if (window.innerWidth >= 768) closeMenu();
                });
            })();
    </script>
</body>
</html>
