        </nav>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="cat-main">
        <!-- Header row -->
        <div class="cat-main-header">
            <div>
                <h1 class="cat-main-title">Explore Tools</h1>
                <p class="cat-main-sub">Discover the best productivity tools for your workflow</p>
            </div>
            <div class="cat-main-search">
                <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
                <input type="text" id="catSearchInput" class="cat-search-input" placeholder="Search tools..." autocomplete="off" />
                <button class="cat-search-clear" id="catSearchClear" aria-label="Clear search" style="display:none">
                    <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
        </div>

        <!-- Tools Grid -->
        <div class="cat-tools-grid" id="toolsGrid">

            <!-- Nén ảnh -->
            <a href ="/moiex/imagecompression" class="cat-tool-card" style="--delay:0s">
                <div class="cat-tool-icon-wrap" style="--icon-color:#4a90e2">
                    <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
                    </svg>

                </div>
                <div class="cat-tool-body">
                    <h3 class="cat-tool-name">Nén ảnh</h3>
                    <p class="cat-tool-desc">Nén ảnh giảm kích thước của ảnh.</p>
                </div>
                <div class="cat-tool-footer">
                    <span class="cat-tool-tag">WORK</span>
                </div>
            </a>
            <!-- Chuyển đổi sang pfd -->
            <a href="/moiex/pdfconverter" class="cat-tool-card" style="--delay:0s">
                <div class="cat-tool-icon-wrap" style="--icon-color:#4a90e2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-file-type-pdf">
                        <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                        <path d="M14 3v4a1 1 0 0 0 1 1h4" />
                        <path d="M5 12v-7a2 2 0 0 1 2 -2h7l5 5v4" />
                        <path d="M5 18h1.5a1.5 1.5 0 0 0 0 -3h-1.5v6" />
                        <path d="M17 18h2" />
                        <path d="M20 15h-3v6" />
                        <path d="M11 15v6h1a2 2 0 0 0 2 -2v-2a2 2 0 0 0 -2 -2h-1" />
                    </svg>
                </div>
                <div class="cat-tool-body">
                    <h3 class="cat-tool-name">Chuyển đổi pdf</h3>
                    <p class="cat-tool-desc">Chuyển đổi file sang file pdf.</p>
                </div>
                <div class="cat-tool-footer">
                    <span class="cat-tool-tag">WORK</span>
                </div>
            </a>
        </div>

        <!-- Load More -->
        @* <div class="cat-load-more-wrap">
            <button class="cat-load-more-btn" id="loadMoreBtn">Load More Tools</button>
        </div> *@
    </main>
</div>

@section Scripts {
    <script>
        (function () {
            // Category filter
            document.querySelectorAll('.cat-nav-item').forEach(function(item) {
                item.addEventListener('click', function(e) {
                    e.preventDefault();
                    document.querySelectorAll('.cat-nav-item').forEach(function(i) { i.classList.remove('is-active'); });
                    item.classList.add('is-active');
                });
            });

            // Like toggle
            document.querySelectorAll('.cat-tool-like').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    btn.classList.toggle('is-liked');
                    var svg = btn.querySelector('svg');
                    if (btn.classList.contains('is-liked')) {
                        svg.setAttribute('fill', 'currentColor');
                    } else {
                        svg.setAttribute('fill', 'none');
                    }
                });
            });

            // Filter buttons toggle active
            document.querySelectorAll('.cat-filter-btn').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    btn.classList.toggle('is-active');
                });
            });

            // Load more (stub animation)
            var loadBtn = document.getElementById('loadMoreBtn');
            if (loadBtn) {
                loadBtn.addEventListener('click', function() {
                    loadBtn.textContent = 'Loading...';
                    loadBtn.disabled = true;
                    setTimeout(function() {
                        loadBtn.textContent = 'No More Tools';
                    }, 1200);
                });
            }

            // Mobile: sidebar toggle
            var sidebarToggle = document.getElementById('catSidebarToggle');
            var sidebar = document.querySelector('.cat-sidebar');
            if (sidebarToggle && sidebar) {
                sidebarToggle.addEventListener('click', function() {
                    sidebar.classList.toggle('is-open');
                });
            }
        })();
    </script>
}
